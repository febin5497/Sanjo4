@finance_bp.route("/project-cost/<int:project_id>", methods=["GET"])
def project_cost(project_id):

    from project_management.models import Project
from middleware.auth_middleware import require_role
    from finance_management.models import Transaction
    from material_management.models import Material
    from staff_management.models import Staff

    project = Project.query.get_or_404(project_id)

    material_cost = 0
    labor_cost = 0
    vehicle_cost = 0

    transactions = Transaction.query.filter_by(project_id=project_id).all()

    for t in transactions:

        if t.category == "material":
            material_cost += t.amount

        elif t.category == "labor":
            labor_cost += t.amount

        elif t.category == "vehicle":
            vehicle_cost += t.amount

    total_cost = material_cost + labor_cost + vehicle_cost

    revenue = project.rate_per_sqft * project.square_feet

    profit = revenue - total_cost

    return jsonify({

        "project": project.name,
        "material_cost": material_cost,
        "labor_cost": labor_cost,
        "vehicle_cost": vehicle_cost,
        "total_cost": total_cost,
        "revenue": revenue,
        "profit": profit

    })