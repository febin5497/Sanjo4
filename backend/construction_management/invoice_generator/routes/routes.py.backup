# Get an invoice by ID
@invoice_bp.route('/<int:invoice_id>', methods=['GET'])
@jwt_required()
def get_invoice_by_id(invoice_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def get_invoice_by_id(invoice_id):
    invoice = Invoice.query.get_or_404(invoice_id)
    return jsonify(invoice.to_dict())

# Delete an invoice by ID
@invoice_bp.route('/<int:invoice_id>', methods=['DELETE'])
@jwt_required()
def delete_invoice(invoice_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def delete_invoice(invoice_id):
    # Fetch the invoice object
    invoice = Invoice.query.get_or_404(invoice_id)

    # Remove all invoice items associated with this invoice
    InvoiceItem.query.filter_by(invoice_id=invoice.id).delete()

    # Delete the invoice itself
    db.session.delete(invoice)
    db.session.commit()

    return jsonify({'message': 'Invoice and its associated items deleted successfully'}), 200

# Download invoice as PDF
@invoice_bp.route('/<int:invoice_id>/download', methods=['GET'])
@jwt_required()
def download_invoice(invoice_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def download_invoice(invoice_id):
    invoice = Invoice.query.get_or_404(invoice_id)

    # Create PDF
    pdf = FPDF()
    pdf.add_page()
    pdf.add_font('DejaVu', '', 'C:/Users/minul/Downloads/construction_management_app/construction_management_app/construction_management/fonts/ttf/DejaVuSans.ttf', uni=True)
    pdf.set_font('DejaVu', '', 12)

    # Add details to PDF
    pdf.cell(200, 10, txt=f"Invoice ID: {invoice.id}", ln=True)
    pdf.cell(200, 10, txt=f"Customer: {invoice.customer}", ln=True)
    pdf.cell(200, 10, txt=f"Total Amount: ₹{invoice.total_amount}", ln=True)
    pdf.cell(200, 10, txt=f"Date: {invoice.date.strftime('%Y-%m-%d')}", ln=True)
    pdf.cell(200, 10, txt="Items:", ln=True)

    # Add items to PDF
    for item in invoice.items:
        pdf.cell(200, 10, txt=f"{item.description} | Qty: {item.quantity} | Rate: ₹{item.rate} | Total: ₹{item.total}", ln=True)

    # Write PDF content to BytesIO object
    pdf_output = BytesIO()
    pdf.output(dest='F', name=pdf_output)
    pdf_output.seek(0)  # Set the pointer to the start of the BytesIO stream

    # Return the PDF file as an attachment
    return send_file(pdf_output, as_attachment=True, download_name=f"Invoice_{invoice.id}.pdf", mimetype="application/pdf")

# Email invoice as PDF
@invoice_bp.route('/email', methods=['POST'])
@jwt_required()
def email_invoice():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def email_invoice():
    data = request.json
    invoice_id = data.get("invoice_id")
    to_email = data.get("to")

    if not invoice_id or not to_email:
        return jsonify({"message": "invoice_id and to (email) are required."}), 400

Invoice.query.filter_by(
    id=invoice_id,
    company_id=user.company_id
).first()
    if not invoice:
        return jsonify({"message": "Invoice not found."}), 404

    # Create PDF for the invoice
    pdf = FPDF()
    pdf.add_page()
    pdf.set_font("Arial", size=12)
    pdf.cell(200, 10, txt=f"Invoice ID: {invoice.id}", ln=True)
    pdf.cell(200, 10, txt=f"Customer: {invoice.customer}", ln=True)
    pdf.cell(200, 10, txt=f"Total Amount: ₹{invoice.total_amount}", ln=True)
    pdf.cell(200, 10, txt=f"Date: {invoice.date.strftime('%Y-%m-%d')}", ln=True)
    pdf.cell(200, 10, txt="Items:", ln=True)

    # Add items to the PDF
    for item in invoice.items:
        pdf.cell(200, 10, txt=f"{item.description} | Qty: {item.quantity} | Rate: ₹{item.rate} | Total: ₹{item.total}", ln=True)

    # Prepare the PDF for emailing
    pdf_output = BytesIO()
    pdf.output(pdf_output)
    pdf_output.seek(0)

    # Send email
    try:
        msg = Message(subject=f"Invoice #{invoice.id}",
                      recipients=[to_email],
                      body=f"Dear {invoice.customer},\n\nPlease find attached the invoice #{invoice.id}.")
        msg.attach(f"Invoice_{invoice.id}.pdf", "application/pdf", pdf_output.read())
        mail.send(msg)
        return jsonify({"message": "Invoice emailed successfully."}), 200
    except Exception as e:
        return jsonify({"message": f"Failed to send email: {str(e)}"}), 500
