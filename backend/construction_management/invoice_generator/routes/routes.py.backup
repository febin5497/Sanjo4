from flask import Blueprint, request, jsonify, send_file
from middleware.auth_middleware import require_role
from flask_jwt_extended import jwt_required
from invoice_generator.models.invoice import Invoice
from invoice_generator.models.invoice_item import InvoiceItem
from extensions import db, mail
from datetime import datetime
from fpdf import FPDF
from flask_mail import Message
from io import BytesIO
import os
from werkzeug.utils import secure_filename

# Blueprint initialization
invoice_bp = Blueprint('invoice', __name__)

@invoice_bp.after_request
def apply_cors_headers(response):
    response.headers["Access-Control-Allow-Origin"] = "http://localhost:5173"
    response.headers["Access-Control-Allow-Credentials"] = "true"
    response.headers["Access-Control-Allow-Headers"] = "Content-Type, Authorization"
    response.headers["Access-Control-Allow-Methods"] = "GET, POST, PUT, DELETE, OPTIONS"
    return response

# Create an invoice
@invoice_bp.route('/', methods=['POST'])
@jwt_required()
def create_invoice():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def create_invoice():
    data = request.json

    # Check for required fields
    if not data.get('customer') or not data.get('total_amount') or not data.get('items'):
        return jsonify({'message': 'Missing required fields: customer, total_amount, or items'}), 400

    # Validate date format
    try:
        date = datetime.strptime(data['date'], '%Y-%m-%d')
    except ValueError:
        return jsonify({'message': 'Invalid date format. Expected YYYY-MM-DD.'}), 400

    # Create the invoice
    invoice = Invoice(
        customer=data['customer'],
        total_amount=data['total_amount'],
        date=date,
        project_id=data.get('project_id')  # Project ID if available
    )

    # Create invoice items
    for item_data in data['items']:
        if 'description' not in item_data or 'quantity' not in item_data or 'rate' not in item_data:
            return jsonify({'message': 'Invalid item data. Each item must have description, quantity, and rate.'}), 400

        item = InvoiceItem(
            description=item_data['description'],
            quantity=item_data['quantity'],
            rate=item_data['rate'],
            total=item_data['quantity'] * item_data['rate'],
            invoice=invoice
        )
        db.session.add(item)

    db.session.add(invoice)
    db.session.commit()

    return jsonify({'message': 'Invoice created successfully', 'id': invoice.id}), 201

