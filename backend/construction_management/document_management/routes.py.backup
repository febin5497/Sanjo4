    ])


# ==============================
# UPLOAD DOCUMENT
# ==============================

@document_bp.route('/documents/upload', methods=['POST'])
@jwt_required()
def upload_document():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def upload_document():

    if 'file' not in request.files:
        return jsonify({"error": "No file part"}), 400

    file = request.files['file']

    if file.filename == '':
        return jsonify({"error": "No selected file"}), 400

    filename = secure_filename(file.filename)

    filepath = os.path.join(UPLOAD_FOLDER, filename)

    file.save(filepath)

    doc = Document(
        filename=filename,
        filepath=filepath
    )

    db.session.add(doc)
    db.session.commit()

    return jsonify({
        "message": "File uploaded",
        "id": doc.id
    }), 201


# ==============================
# DELETE DOCUMENT
# ==============================

@document_bp.route('/documents/<int:doc_id>', methods=['DELETE'])
@jwt_required()
def delete_document(doc_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def delete_document(doc_id):

    doc = Document.query.get_or_404(doc_id)

    try:
        os.remove(doc.filepath)
    except FileNotFoundError:
        pass

    db.session.delete(doc)
    db.session.commit()

    return jsonify({
        "message": "Document deleted"
    })


# ==============================
# DOWNLOAD DOCUMENT
# ==============================

@document_bp.route('/documents/download/<filename>', methods=['GET'])
@jwt_required()
def download_document(filename):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def download_document(filename):

    return send_from_directory(UPLOAD_FOLDER, filename, as_attachment=True)


# ====================================================
# SITE PROGRESS PHOTOS (NEW FEATURE)
# ====================================================

@document_bp.route('/site-photos', methods=['GET'])
@jwt_required()
def list_site_photos():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def list_site_photos():

    files = os.listdir(SITE_PHOTO_FOLDER)

    return jsonify(files)


@document_bp.route('/site-photos/upload', methods=['POST'])
@jwt_required()
def upload_site_photo():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def upload_site_photo():

    if 'file' not in request.files:
        return jsonify({"error": "No file provided"}), 400

    file = request.files['file']

    filename = secure_filename(file.filename)

    filepath = os.path.join(SITE_PHOTO_FOLDER, filename)

    file.save(filepath)

    return jsonify({
        "message": "Site photo uploaded",
        "filename": filename
    })


@document_bp.route('/site-photos/<filename>', methods=['GET'])
def view_site_photo(filename):

    return send_from_directory(SITE_PHOTO_FOLDER, filename)


@document_bp.route('/site-photos/<filename>', methods=['DELETE'])
@jwt_required()
def delete_site_photo(filename):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def delete_site_photo(filename):

    filepath = os.path.join(SITE_PHOTO_FOLDER, filename)

    if os.path.exists(filepath):
        os.remove(filepath)

    return jsonify({
        "message": "Photo deleted"
    })