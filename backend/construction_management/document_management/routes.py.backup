import os
from middleware.auth_middleware import require_role
from flask import Blueprint, request, jsonify, send_from_directory
from flask_jwt_extended import jwt_required
from werkzeug.utils import secure_filename
from document_management.models import Document, db

# Document folder
UPLOAD_FOLDER = os.path.join(os.getcwd(), 'documents')

# Site photo folder
SITE_PHOTO_FOLDER = os.path.join(os.getcwd(), 'site_photos')

os.makedirs(UPLOAD_FOLDER, exist_ok=True)
os.makedirs(SITE_PHOTO_FOLDER, exist_ok=True)

document_bp = Blueprint('document', __name__)


# ==============================
# LIST DOCUMENTS
# ==============================

@document_bp.route('/documents', methods=['GET'])
@jwt_required()
def list_documents():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def list_documents():

Document.query.filter_by(company_id=user.company_id).all()

    return jsonify([
