    return jsonify([material.to_dict() for material in materials])

# Get a specific material by ID
@material_bp.route('/<int:material_id>', methods=['GET'])
def get_material(material_id):
    material = Material.query.get_or_404(material_id)
    return jsonify(material.to_dict())

# Update material details
@material_bp.route('/<int:material_id>', methods=['PUT'])
def update_material(material_id):
    material = Material.query.get_or_404(material_id)
    data = request.json

    # Update material fields
    material.name = data.get('name', material.name)
    material.description = data.get('description', material.description)
    material.quantity = data.get('quantity', material.quantity)
    material.unit_of_measurement = data.get('unit_of_measurement', material.unit_of_measurement)
    material.price = data.get('price', material.price)
    material.project_id = data.get('project_id', material.project_id)

    db.session.commit()
    return jsonify({'message': 'Material updated successfully'})

# Delete material by ID
@material_bp.route('/<int:material_id>', methods=['DELETE'])
def delete_material(material_id):
    material = Material.query.get_or_404(material_id)
    db.session.delete(material)
    db.session.commit()
    return jsonify({'message': 'Material deleted successfully'})
