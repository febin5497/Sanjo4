from flask import Blueprint, request, jsonify
from middleware.auth_middleware import require_role
from material_management.models import Material
from extensions import db

material_bp = Blueprint('material', __name__)

# Create a new material
@material_bp.route('/', methods=['POST'])
def create_material():
    data = request.json

    if not data.get('name') or not data.get('quantity') or not data.get('price'):
        return jsonify({'error': 'Missing required fields'}), 400

    material = Material(
        name=data.get('name'),
        description=data.get('description'),
        quantity=data.get('quantity'),
        unit_of_measurement=data.get('unit_of_measurement'),
        price=data.get('price'),
        project_id=data.get('project_id')  # Link to project if available
    )

    db.session.add(material)
    db.session.commit()
    
    return jsonify({'message': 'Material created successfully', 'id': material.id}), 201

# Get all materials
@material_bp.route('/', methods=['GET'])
def get_materials():
