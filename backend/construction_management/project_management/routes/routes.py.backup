from flask import Blueprint, request, jsonify
from middleware.auth_middleware import require_role
from flask_jwt_extended import jwt_required, get_jwt_identity
from extensions import db
import os
from werkzeug.utils import secure_filename
from datetime import datetime
from sqlalchemy.orm import joinedload

from project_management.models import Project

project_bp = Blueprint('project', __name__)

BASE_UPLOAD_FOLDER = os.path.join(os.getcwd(), 'uploads')
ALLOWED_EXTENSIONS = {'pdf', 'jpg', 'jpeg', 'png'}

os.makedirs(BASE_UPLOAD_FOLDER, exist_ok=True)


def allowed_file(filename):
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS


# -----------------------------
# GET PROJECTS
# -----------------------------
@project_bp.route('/', methods=['GET'])
@jwt_required(optional=True)
def get_projects():

    page = request.args.get('page', 1, type=int)
    per_page = request.args.get('per_page', 10, type=int)

    if page <= 0 or per_page <= 0:
        return jsonify({"error": "Page and per_page must be positive integers"}), 400

    paginated = Project.query.options(joinedload(Project.client)).paginate(
        page=page,
        per_page=per_page,
        error_out=False
    )

    return jsonify({
        "projects": [p.to_dict() for p in paginated.items],
        "page": paginated.page,
        "per_page": paginated.per_page,
        "total": paginated.total,
        "pages": paginated.pages
    })


# -----------------------------
# CREATE PROJECT
# -----------------------------
@project_bp.route('/', methods=['POST'])
@jwt_required()
def create_project():
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def create_project():

    from staff_management.models import Staff

    current_user_id = get_jwt_identity()
Staff.query.filter_by(
    id=current_user_id,
    company_id=user.company_id
).first()

    if not user or user.role != 'admin':
        return jsonify({"error": "Unauthorized access"}), 403

    data = request.get_json()

    if not data or not data.get('name') or not data.get('location'):
        return jsonify({"error": "Project name and location are required"}), 400

    try:
        start_date = datetime.strptime(data.get('start_date'), '%Y-%m-%d').date()
    except Exception:
        return jsonify({"error": "Invalid date format. Use YYYY-MM-DD"}), 400

    new_project = Project(
        name=data.get('name'),
        location=data.get('location'),
        start_date=start_date,
        user_id=current_user_id,
        rate_per_sqft=data.get('rate_per_sqft'),
        square_feet=data.get('square_feet'),
        status=data.get('status', 'Planned'),
        client_id=data.get('client_id')
    )

    db.session.add(new_project)
    db.session.commit()

    return jsonify({
        "message": "Project created successfully",
        "project": new_project.to_dict()
    }), 201


# -----------------------------
# GET PROJECT BY ID
# -----------------------------
@project_bp.route('/<int:project_id>', methods=['GET'])
@jwt_required(optional=True)
def get_project_by_id(project_id):

    project = Project.query.get_or_404(project_id)

    return jsonify(project.to_dict())


# -----------------------------
# UPDATE PROJECT
# -----------------------------
@project_bp.route('/<int:project_id>', methods=['PUT'])
@jwt_required()
def update_project(project_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def update_project(project_id):

    data = request.get_json()
    project = Project.query.get_or_404(project_id)

    project.name = data.get('name', project.name)
    project.location = data.get('location', project.location)

    if data.get('start_date'):
        try:
            project.start_date = datetime.strptime(
                data.get('start_date'),
                '%Y-%m-%d'
            ).date()
        except ValueError:
            return jsonify({"error": "Invalid date format"}), 400

    project.rate_per_sqft = data.get('rate_per_sqft', project.rate_per_sqft)
    project.square_feet = data.get('square_feet', project.square_feet)
    project.status = data.get('status', project.status)
    project.client_id = data.get('client_id', project.client_id)

    db.session.commit()

    return jsonify({
        "message": "Project updated successfully",
        "project": project.to_dict()
    })


# -----------------------------
# DELETE PROJECT
# -----------------------------
@project_bp.route('/<int:project_id>', methods=['DELETE'])
@jwt_required()
def delete_project(project_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def delete_project(project_id):

    project = Project.query.get_or_404(project_id)

    db.session.delete(project)
    db.session.commit()

    return jsonify({"message": "Project deleted successfully"})


# -----------------------------
# PROJECT LOCATION
