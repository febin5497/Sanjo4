# Get a specific vehicle by ID
@vehicle_bp.route('/vehicles/<int:vehicle_id>', methods=['GET'])
@jwt_required()
def get_vehicle(vehicle_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def get_vehicle(vehicle_id):
    vehicle = Vehicle.query.get_or_404(vehicle_id)
    return jsonify(vehicle.to_dict())

# Update a vehicle's details
@vehicle_bp.route('/vehicles/<int:vehicle_id>', methods=['PUT'])
@jwt_required()
def update_vehicle(vehicle_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def update_vehicle(vehicle_id):
    vehicle = Vehicle.query.get_or_404(vehicle_id)
    data = request.json
    
    # Check if the vehicle type is valid
    if 'type' in data and not validate_vehicle_type(data.get('type')):
        return jsonify({'error': 'Invalid vehicle type'}), 400

    # Update vehicle fields
    vehicle.make = data.get('make', vehicle.make)
    vehicle.model = data.get('model', vehicle.model)
    vehicle.year = data.get('year', vehicle.year)
    vehicle.registration_number = data.get('registration_number', vehicle.registration_number)
    vehicle.mileage = data.get('mileage', vehicle.mileage)
    vehicle.status = data.get('status', vehicle.status)
    vehicle.type = data.get('type', vehicle.type)

    # Update date fields with proper parsing
    vehicle.registration_date = parse_date(data.get('registration_date', vehicle.registration_date))
    vehicle.pollution_date = parse_date(data.get('pollution_date', vehicle.pollution_date))
    vehicle.insurance_date = parse_date(data.get('insurance_date', vehicle.insurance_date))
    vehicle.tax_date = parse_date(data.get('tax_date', vehicle.tax_date))
    vehicle.geology_certificate_date = parse_date(data.get('geology_certificate_date', vehicle.geology_certificate_date))

    vehicle.emi_status = data.get('emi_status', vehicle.emi_status)
    
    db.session.commit()
    return jsonify({'message': 'Vehicle updated successfully'})

# Delete a vehicle by ID
@vehicle_bp.route('/vehicles/<int:vehicle_id>', methods=['DELETE'])
@jwt_required()
def delete_vehicle(vehicle_id):
    user = require_role(["admin","manager"])

    if isinstance(user, tuple):
        return user

def delete_vehicle(vehicle_id):
    vehicle = Vehicle.query.get_or_404(vehicle_id)
    db.session.delete(vehicle)
    db.session.commit()
    return jsonify({'message': 'Vehicle deleted successfully'})
